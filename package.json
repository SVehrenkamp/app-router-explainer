{
  "name": "app-router-explainer",
  "private": true,
  "scripts": {
    "dev": "yarn snapshot && next dev",
    "build": "yarn snapshot && NEXT_PRIVATE_STANDALONE=true next build && yarn metrics && opennextjs-cloudflare build --skipNextBuild",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "preview": "yarn build && opennextjs-cloudflare preview",
    "deploy": "yarn build && opennextjs-cloudflare deploy",
    "upload": "yarn build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "snapshot": "node --experimental-strip-types scripts/snapshot-source.mts",
    "metrics": "node scripts/journey-metrics.mjs"
  },
  "dependencies": {
    "@tanstack/react-query": "5.83.1",
    "next": "15.5.18",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "server-only": "0.0.1",
    "shiki": "4.3.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@opennextjs/cloudflare": "^1.20.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.2",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "tailwindcss": "4.3.2",
    "typescript": "^5",
    "vitest": "4.1.10",
    "wrangler": "^4.107.0"
  },
  "packageManager": "yarn@4.5.0"
}
